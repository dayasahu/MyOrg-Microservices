{
  "info": {
    "_postman_id": "8de1f61f-2e62-4d4d-8d44-microservices-training",
    "name": "microservices-training",
    "description": "Import this collection into Postman. Run 'Auth - Get JWT Token' first; it saves jwt_token for the protected API calls.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://api.myorg.com",
      "type": "string"
    },
    {
      "key": "jwt_token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth - Get JWT Token",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Token returned', function () {",
              "    pm.response.to.have.status(200);",
              "    var json = pm.response.json();",
              "    pm.expect(json.token).to.be.a('string');",
              "    pm.collectionVariables.set('jwt_token', json.token);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"userId\": \"12345\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/auth/token",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "auth",
            "token"
          ]
        }
      },
      "response": []
    },
    {
